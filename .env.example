DATABASE_URL=file:./lichtblick.db
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Admin user created by `pnpm seed`. Without these, the seed falls back to the
# public demo credentials from the README (fine locally, never for production).
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=choose-a-strong-password

# Contact form (optional in dev: without a key, submissions are logged to the server console)
# RESEND_API_KEY=re_...
# CONTACT_TO_EMAIL=studio@example.com
# CONTACT_FROM_EMAIL=Studio Lichtblick <onboarding@resend.dev>
