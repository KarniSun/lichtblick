# --- Local development (defaults) ---
# SQLite file; leave as-is for local dev.
DATABASE_URL=file:./lichtblick.db
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Admin user created by `pnpm seed`. Without these, the seed falls back to the
# public demo credentials from the README (fine locally, never for production).
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=choose-a-strong-password

# --- Production (Vercel env vars; also used for the one-time prod seed) ---
# Turso (libSQL) database — same adapter as local, just remote:
# DATABASE_URL=libsql://<db>-<user>.turso.io
# DATABASE_AUTH_TOKEN=<turso read-write token>
# Vercel Blob — activates cloud media storage when present:
# BLOB_READ_WRITE_TOKEN=<vercel blob token>
# Absolute site URL (drives sitemap/robots/OG links):
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Contact form (optional; demo mode without these — confirms but sends nothing)
# RESEND_API_KEY=re_...
# CONTACT_TO_EMAIL=studio@example.com
# CONTACT_FROM_EMAIL=Studio Lichtblick <onboarding@resend.dev>
